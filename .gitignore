# Ignore everything
*

# Allow GitHub workflows
!.github/
!.github/**



# But allow these folders
!frontend/
!backend/

# Allow git to see files inside them
!frontend/**
!backend/**

# Allow .gitignore itself
!.gitignore


# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Uploads
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/

# Production
build/
dist/
frontend/build/

# Misc
.cache/
.temp/
.tmp/
